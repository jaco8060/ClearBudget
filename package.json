{
  "name": "budget-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "db:init:local": "wrangler d1 execute budget-db --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute budget-db --remote --file=./schema.sql",
    "pages:dev": "wrangler pages dev -- npm run dev",
    "build": "vite build",
    "deploy": "npm run build && wrangler pages deploy dist",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/material": "^7.3.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.8.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.36.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.22",
    "globals": "^16.4.0",
    "vite": "^7.1.7",
    "wrangler": "^4.78.0"
  }
}
